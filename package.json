{
  "name": "fantasy-db",
  "version": "0.1.0",
  "private": true,
  "description": "Ingest NFL stats from nflverse into a local DuckDB for fantasy football analytics",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ingest": "tsx src/ingest.ts",
    "ingest:all": "tsx src/ingest.ts --all",
    "query": "tsx src/query.ts",
    "list": "tsx src/ingest.ts --list",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.4-r.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
